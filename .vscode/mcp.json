{
	"servers": {
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${env:GITHUB_TOKEN}",
				"ghcr.io/github/github-mcp-server:1.4.0"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.4.0"
		},
		"firecrawl/firecrawl-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"firecrawl-mcp@latest"
			],
			"env": {
				"FIRECRAWL_API_KEY": "${env:FIRECRAWL_API_KEY}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"Perplexity": {
			"command": "/vscode/bin/linux-x64/fcf604774b9f2674b473065736ee75077e256353/node",
			"args": [
				"/home/codespace/.perplexity-mcp/start.mjs"
			],
			"env": {},
			"type": "stdio"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"microsoft/markitdown": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"markitdown-mcp@0.0.1a4"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"io.github.tavily-ai/tavily-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"tavily-mcp@0.2.15"
			],
			"env": {
				"TAVILY_API_KEY": "${input:TAVILY_API_KEY}",
				"DEFAULT_PARAMETERS": "${input:DEFAULT_PARAMETERS}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.2.15"
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		},
		{
			"id": "api_key",
			"type": "promptString",
			"description": "your API key",
			"password": true
		},
		{
			"id": "TAVILY_API_KEY",
			"type": "promptString",
			"description": "Your Tavily API key from tavily.com",
			"password": true
		},
		{
			"id": "DEFAULT_PARAMETERS",
			"type": "promptString",
			"description": "JSON string with default search parameters (e.g., {\"include_images\": true, \"max_results\": 15})",
			"password": false
		}
	]
}